# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SQLITE_DB_PATH: SQLite database file path.
# Relative paths are resolved from the project root.
SQLITE_DB_PATH="data/gjj.sqlite"

# CRM_PUSH_TOKEN: Token required by POST /api/crm/push.
# Send it with request header: X-CRM-PUSH-TOKEN.
CRM_PUSH_TOKEN="CHANGE_ME_TO_A_LONG_RANDOM_TOKEN"

# CRM_FEISHU_TABLE_URL: Optional default target table for manual/cron CRM sync.
# The admin CRM page can also send the target URL in the sync request.
CRM_FEISHU_TABLE_URL=""

# AI training OpenAI settings are configured in Admin > 基础设置.
